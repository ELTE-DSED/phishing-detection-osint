# PhishGuard Frontend — Local Environment Variables
# Copy this file to .env.local and adjust as needed.

# Backend API base URL (used both by next.config.ts rewrites and the API client)
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (set this in Vercel environment variables):
# NEXT_PUBLIC_API_URL=https://your-app.onrender.com
