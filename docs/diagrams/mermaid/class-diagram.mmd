classDiagram
class AnalyzeRequest {
<<Pydantic>>
+str content
+str contentType "auto" | "url" | "email" | "text"
+validateContent(v: str) str
}

class AnalysisResponse {
<<Pydantic>>
+bool success
+VerdictResult verdict
+OsintSummary osint
+FeatureSummary features
+float analysisTime ms
+datetime analyzedAt
+str error
}

class VerdictResult {
<<Pydantic>>
+bool isPhishing
+str threatLevel "safe" | "suspicious" | "dangerous" | "critical"
+float confidenceScore 0.0-1.0
+list~str~ reasons
+str recommendation
}

class OsintSummary {
<<Pydantic>>
+str domain
+int domainAgeDays
+str registrar
+bool isPrivate
+bool hasValidDns
+float reputationScore
+bool inBlacklists
}

class FeatureSummary {
<<Pydantic>>
+int urlFeatures
+int textFeatures
+int osintFeatures
+int totalRiskIndicators
+list~str~ detectedTactics
}

class FeatureSet {
<<Pydantic>>
+str url
+str domain
+UrlFeatures urlFeatures
+OsintFeatures osintFeatures
+float extractionDurationMs
+toVector ndarray 29
+toModelVector ndarray 21
}

class UrlFeatures {
<<Pydantic>>
+int urlLength
+int domainLength
+int subdomainCount
+int pathDepth
+bool hasIpAddress
+bool hasAtSymbol
+bool hasDoubleSlash
+bool hasDashInDomain
+bool hasUnderscoreInDomain
+bool isHttps
+bool hasPortNumber
+bool hasSuspiciousTld
+bool hasEncodedChars
+bool hasSuspiciousKeywords
+float digitRatio
+int specialCharCount
+int queryParamCount
}

class OsintFeatures {
<<Pydantic>>
+int domainAgeDays
+bool isNewlyRegistered
+bool isYoungDomain
+bool hasPrivacyProtection
+bool hasValidMx
+bool usesCdn
+int dnsRecordCount
+bool hasValidDns
+float reputationScore
+int maliciousSourceCount
+bool isKnownMalicious
+bool hasValidWhois
}

AnalyzeRequest ..> AnalysisResponse : initiates
AnalysisResponse "1" *-- "1" VerdictResult : contains
AnalysisResponse "1" *-- "0..1" OsintSummary : contains
AnalysisResponse "1" *-- "1" FeatureSummary : contains
FeatureSummary ..> FeatureSet : derived from
FeatureSet "1" *-- "1" UrlFeatures : contains
FeatureSet "1" *-- "1" OsintFeatures : contains