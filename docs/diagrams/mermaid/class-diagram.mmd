classDiagram
    class AnalyzeRequest {
        <<Pydantic>>
        +str content
        +str contentType "auto" | "url" | "email" | "text"
        +validateContent(v: str) str
    }

    class AnalysisResponse {
        <<Pydantic>>
        +str id
        +str content
        +str contentType
        +VerdictResult verdict
        +FeatureSummary features
        +OsintSummary osint
        +AnalysisTiming timing
    }

    class VerdictResult {
        <<Pydantic>>
        +bool isPhishing
        +str threatLevel "safe" | "suspicious" | "dangerous" | "critical"
        +float confidenceScore 0.0-1.0
        +list[str] reasons
        +str recommendation
    }

    class FeatureSummary {
        <<Pydantic>>
        +dict[str, float] urlFeatures
        +list[DetectedIndicator] textIndicators
    }

    class OsintSummary {
        <<Pydantic>>
        +dict[str, str] domainInfo
        +list[str] dnsRecords
        +float reputationScore
        +bool isBlacklisted
    }

    class FeatureSet {
        <<Pydantic>>
        +int urlLength
        +int domainLength
        +int subdomainCount
        +int pathDepth
        +bool hasIpAddress
        +bool hasAtSymbol
        +bool hasDoubleSlash
        +bool hasDashInDomain
        +bool hasUnderscoreInDomain
        +bool isHttps
        +bool hasPortNumber
        +bool hasSuspiciousTld
        +bool hasEncodedChars
        +bool hasSuspiciousKeywords
        +float digitRatio
        +int specialCharCount
        +int queryParamCount
        +int domainAgeDays
        +bool isNewlyRegistered
        +bool isYoungDomain
        +bool hasPrivacyProtection
        +bool hasValidMx
        +bool usesCdn
        +int dnsRecordCount
        +bool hasValidDns
        +float reputationScore
        +int maliciousSourceCount
        +bool isKnownMalicious
        +bool hasValidWhois
    }

    AnalyzeRequest ..> AnalysisResponse : initiates
    AnalysisResponse "1" *-- "1" VerdictResult : contains
    AnalysisResponse "1" *-- "1" FeatureSummary : contains
    AnalysisResponse "1" *-- "1" OsintSummary : contains
    FeatureSummary ..> FeatureSet : derived from
